#!/usr/bin/env bash
# list-runtime-assets — parse the runtime-asset manifest (runtime-assets.md)
# and emit the install/ownership asset list (ADR-061).
#
# This is the kit's machine-parser of the manifest table. The installer,
# the ADR-059 upgrade planner, and (later) ADR-060 profile logic derive
# their asset lists from this output rather than from a hardcoded array.
# bin/check-manifest validates the same file; this script emits it.
#
# Strict by design (ADR-061 parser contract):
#   - A row that does not parse — wrong cell count, unknown profile or
#     ownership value, bad id — is a HARD ERROR naming the row. Rows are
#     never silently dropped.
#   - A missing or unparseable manifest ABORTS. There is no fallback to a
#     hardcoded list.
#   - An unknown schemaVersion major is rejected rather than guessed.
#   - Missing sources: a required asset whose source is absent from the
#     kit tree is a fail-fast error (all missing required accumulated and
#     reported once); an optional asset whose source is absent warns and
#     is omitted from the emitted list.
#
# --allow-missing is TEST-ONLY and loud: it downgrades missing *required*
# sources to warnings (and omits those rows), printing a prominent banner
# naming every asset it skipped. It is never used by the shipped install
# path. Only source-missing is downgraded; every other strictness rule
# still applies.
#
# --profile=<name> emits only rows whose profiles column includes <name>.
# The value must be in the closed vocabulary (currently { full }); an
# unknown profile is an invocation error, not an empty result.
#
# Usage:
#   bin/list-runtime-assets [--manifest PATH] [--profile NAME]
#                           [--allow-missing] [--format text|json] [-h]
#
# Output:
#   text (default) — one tab-separated row per emitted asset, no header:
#       id <TAB> source <TAB> dest <TAB> required <TAB> profiles
#           <TAB> ownership <TAB> since-version
#     Warnings and banners go to stderr; stdout carries only asset rows,
#     so the installer can read it with `while IFS=$'\t' read`.
#   json — the standard envelope with outputs.assets[] (one object per
#     emitted asset).
#
# Exit codes (shared convention; see lib/json-envelope.sh):
#   0  parsed; asset list emitted (warnings possible)
#   1  constraint violation (malformed row, missing required source, …)
#   2  invocation error (manifest missing/unreadable, bad flags, unknown
#      --profile value)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=lib/json-envelope.sh
. "$SCRIPT_DIR/lib/json-envelope.sh"

usage() { sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'; }

FORMAT="text"
MANIFEST="runtime-assets.md"
PROFILE="full"
ALLOW_MISSING=0
while [ $# -gt 0 ]; do
  case "$1" in
    --format)
      [ $# -ge 2 ] || { printf 'list-runtime-assets: --format needs an argument\n' >&2; exit "$ENVELOPE_EXIT_INVOCATION"; }
      FORMAT="$2"; shift 2 ;;
    --format=*) FORMAT="${1#*=}"; shift ;;
    --manifest)
      [ $# -ge 2 ] || { printf 'list-runtime-assets: --manifest needs an argument\n' >&2; exit "$ENVELOPE_EXIT_INVOCATION"; }
      MANIFEST="$2"; shift 2 ;;
    --manifest=*) MANIFEST="${1#*=}"; shift ;;
    --profile)
      [ $# -ge 2 ] || { printf 'list-runtime-assets: --profile needs an argument\n' >&2; exit "$ENVELOPE_EXIT_INVOCATION"; }
      PROFILE="$2"; shift 2 ;;
    --profile=*) PROFILE="${1#*=}"; shift ;;
    --allow-missing) ALLOW_MISSING=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) printf 'list-runtime-assets: unknown argument: %s\n' "$1" >&2; exit "$ENVELOPE_EXIT_INVOCATION" ;;
  esac
done
case "$FORMAT" in
  text|json) ;;
  *) printf 'list-runtime-assets: --format must be text or json (got: %s)\n' "$FORMAT" >&2; exit "$ENVELOPE_EXIT_INVOCATION" ;;
esac

if [ ! -f "$MANIFEST" ] || [ ! -r "$MANIFEST" ]; then
  printf 'list-runtime-assets: manifest not found or unreadable: %s (run from the kit repo root)\n' "$MANIFEST" >&2
  printf 'list-runtime-assets: a missing manifest is a hard error; there is no fallback asset list.\n' >&2
  exit "$ENVELOPE_EXIT_INVOCATION"
fi

if [ "$ALLOW_MISSING" -eq 1 ]; then
  {
    printf '****************************************************************\n'
    printf '*** list-runtime-assets: --allow-missing is active (TEST).  ***\n'
    printf '*** Missing REQUIRED sources are downgraded to warnings.    ***\n'
    printf '*** Never use this on the shipped install path.             ***\n'
    printf '****************************************************************\n'
  } >&2
fi

RESULT=$(
  MANIFEST_PATH="$MANIFEST" ALLOW_MISSING="$ALLOW_MISSING" PROFILE="$PROFILE" \
  python3 <<'PYEOF'
import json, os, re, sys

manifest_path = os.environ["MANIFEST_PATH"]
allow_missing = os.environ.get("ALLOW_MISSING") == "1"
profile = os.environ["PROFILE"]

KNOWN_SCHEMA_MAJORS = {1}
COLUMNS = ["id", "source", "dest", "required", "profiles", "ownership", "since-version"]
REQUIRED_VOCAB = {"required", "optional"}
PROFILE_VOCAB = {"full"}
OWNERSHIP_VOCAB = {"kit-owned", "generated", "user-seeded"}
ID_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")


def emit(exit_code, status, outputs, text):
    print(json.dumps({"exit": exit_code, "status": status,
                      "outputs": outputs, "text": text}, ensure_ascii=False))
    sys.exit(0)


# An unknown --profile value is an invocation error, not an empty list.
if profile not in PROFILE_VOCAB:
    emit(2, "bad-profile",
         {"problems": ["unknown profile %r (closed vocabulary: %s)"
                       % (profile, ", ".join(sorted(PROFILE_VOCAB)))]},
         "list-runtime-assets: unknown profile %r (known: %s)"
         % (profile, ", ".join(sorted(PROFILE_VOCAB))))

try:
    with open(manifest_path, encoding="utf-8") as fh:
        lines = fh.read().split("\n")
except Exception as e:
    emit(2, "unreadable", {"problems": ["manifest unreadable: %s" % e]},
         "list-runtime-assets: manifest unreadable: %s" % e)

problems = []
warnings = []
downgraded = []

# ---- schemaVersion --------------------------------------------------------
sv_matches = [(i + 1, m.group(1)) for i, ln in enumerate(lines)
              if (m := re.match(r"^schemaVersion:\s*(.+?)\s*$", ln))]
if not sv_matches:
    problems.append("no `schemaVersion:` declaration found")
elif len(sv_matches) > 1:
    problems.append("multiple schemaVersion declarations (lines %s)"
                    % ", ".join(str(n) for n, _ in sv_matches))
else:
    lineno, val = sv_matches[0]
    if not val.isdigit():
        problems.append("schemaVersion %r (line %d) is not an integer" % (val, lineno))
    elif int(val) not in KNOWN_SCHEMA_MAJORS:
        problems.append("schemaVersion %s is not a known major (known: %s); refusing to guess"
                        % (val, ", ".join(str(v) for v in sorted(KNOWN_SCHEMA_MAJORS))))


# ---- locate the table -----------------------------------------------------
def cells_of(line):
    body = line.strip()
    if not (body.startswith("|") and body.endswith("|") and len(body) >= 2):
        return None
    return [c.strip() for c in body[1:-1].split("|")]


def is_separator(cs):
    return cs is not None and all(re.fullmatch(r":?-+:?", c) for c in cs)


header_idxs = [i for i, ln in enumerate(lines)
               if (cs := cells_of(ln)) is not None
               and [c.lower() for c in cs] == COLUMNS]

table_lines = set()
rows = []
if not header_idxs:
    problems.append("no manifest table header found (expected columns: | %s |)"
                    % " | ".join(COLUMNS))
elif len(header_idxs) > 1:
    problems.append("multiple manifest table headers (lines %s)"
                    % ", ".join(str(i + 1) for i in header_idxs))
else:
    h = header_idxs[0]
    table_lines.add(h)
    if h + 1 >= len(lines) or not is_separator(cells_of(lines[h + 1])):
        problems.append("manifest table header (line %d) is not followed by a separator row" % (h + 1))
    else:
        table_lines.add(h + 1)
        j = h + 2
        while j < len(lines) and lines[j].strip().startswith("|"):
            table_lines.add(j)
            rows.append((j + 1, cells_of(lines[j])))
            j += 1
        if not rows:
            problems.append("manifest table has no data rows")

# A pipe-line outside the recognised table is a stray row: never silently
# ignored (that would recreate the drop-a-row failure this ADR ends).
for i, ln in enumerate(lines):
    if ln.strip().startswith("|") and i not in table_lines:
        problems.append("table row outside the manifest table at line %d: %s"
                        % (i + 1, ln.strip()[:60]))


# ---- per-row parse + validate ---------------------------------------------
def rel_path_problem(p):
    if p.startswith("/") or re.match(r"^[A-Za-z]:", p):
        return "is absolute"
    if "\\" in p:
        return "contains a backslash"
    if ".." in p.split("/"):
        return "contains `..`"
    return None


seen_ids = {}
seen_dests = {}
assets = []
for lineno, cs in rows:
    name = (cs[0] if cs and cs[0] else "line %d" % lineno)
    if cs is None or len(cs) != len(COLUMNS) or any(c == "" for c in cs):
        got = "unparseable" if cs is None else "%d cell(s)%s" % (
            len(cs), "; empty cell(s)" if len(cs) == len(COLUMNS) else "")
        problems.append("row %r (line %d): expected %d non-empty cells, got %s"
                        % (name, lineno, len(COLUMNS), got))
        continue  # cannot trust the columns of a malformed row
    aid, source, dest, required, profiles, ownership, since = cs

    if not ID_RE.fullmatch(aid):
        problems.append("row %r (line %d): id does not match ^[a-z0-9][a-z0-9-]*$" % (aid, lineno))
    if aid in seen_ids:
        problems.append("row %r (line %d): duplicate id (first at line %d)" % (aid, lineno, seen_ids[aid]))
    else:
        seen_ids[aid] = lineno

    if required not in REQUIRED_VOCAB:
        problems.append("row %r (line %d): required must be one of %s (got %r)"
                        % (aid, lineno, "|".join(sorted(REQUIRED_VOCAB)), required))

    tokens = [t.strip() for t in profiles.split(",")]
    if not tokens or any(t == "" for t in tokens):
        problems.append("row %r (line %d): profiles list is empty or has an empty entry" % (aid, lineno))
    else:
        for t in tokens:
            if t not in PROFILE_VOCAB:
                problems.append("row %r (line %d): unknown profile %r (closed vocabulary: %s)"
                                % (aid, lineno, t, ", ".join(sorted(PROFILE_VOCAB))))
        if len(tokens) != len(set(tokens)):
            problems.append("row %r (line %d): duplicate profile tokens" % (aid, lineno))

    if ownership not in OWNERSHIP_VOCAB:
        problems.append("row %r (line %d): ownership must be one of %s (got %r)"
                        % (aid, lineno, " | ".join(sorted(OWNERSHIP_VOCAB)), ownership))

    dp = rel_path_problem(dest)
    if dp:
        problems.append("row %r (line %d): dest %s (%s)" % (aid, lineno, dp, dest))
    if dest in seen_dests:
        problems.append("row %r (line %d): duplicate dest %r (first at line %d)"
                        % (aid, lineno, dest, seen_dests[dest]))
    else:
        seen_dests[dest] = lineno

    if not since:
        problems.append("row %r (line %d): since-version is empty" % (aid, lineno))

    # Source existence is checked per row; the outcome (error / warn /
    # downgrade / omit) is resolved after we know required vs optional.
    source_present = True
    sp = rel_path_problem(source)
    if sp:
        problems.append("row %r (line %d): source %s (%s)" % (aid, lineno, sp, source))
        source_present = False
    else:
        is_dir_row = source.endswith("/")
        path = source.rstrip("/")
        source_present = os.path.isdir(path) if is_dir_row else os.path.isfile(path)
        if not source_present:
            kind = "directory" if is_dir_row else "file"
            msg = "row %r (line %d): source %s missing from the kit tree (%s)" % (aid, lineno, kind, source)
            if required == "required" and not allow_missing:
                problems.append(msg)
            elif required == "required":
                downgraded.append(aid)
                warnings.append("(downgraded by --allow-missing): " + msg)
            else:
                warnings.append("optional " + msg)

    assets.append({
        "lineno": lineno, "id": aid, "source": source, "dest": dest,
        "required": required, "profiles": tokens, "ownership": ownership,
        "since": since, "source_present": source_present,
    })

# If any hard problem exists, do not emit a partial list: fail whole.
if problems:
    text = ("list-runtime-assets: INVALID — %d problem(s):\n" % len(problems)
            + "\n".join("  - " + p for p in problems))
    emit(1, "invalid", {"manifest": manifest_path, "problems": problems, "warnings": warnings}, text)

# Filter to the requested profile and drop rows whose source is absent
# (optional-missing, or required-missing under --allow-missing). A present
# required source that failed no other check always survives.
emitted = []
for a in assets:
    if profile not in a["profiles"]:
        continue
    if not a["source_present"]:
        continue  # already warned above; cannot install a missing source
    emitted.append(a)

out_assets = [{"id": a["id"], "source": a["source"], "dest": a["dest"],
               "required": a["required"], "profiles": a["profiles"],
               "ownership": a["ownership"], "since": a["since"]} for a in emitted]
outputs = {"manifest": manifest_path, "profile": profile,
           "schemaVersion": sv_matches[0][1] if len(sv_matches) == 1 else None,
           "count": len(out_assets), "allowMissing": allow_missing,
           "downgraded": downgraded, "assets": out_assets, "warnings": warnings}

# text payload: one TSV row per emitted asset (stdout carries only rows).
tsv = "\n".join("\t".join([a["id"], a["source"], a["dest"], a["required"],
                           ",".join(a["profiles"]), a["ownership"], a["since"]])
                for a in emitted)
emit(0, "ok", outputs, tsv)
PYEOF
)

EXIT_HINT=$(printf '%s' "$RESULT" | jq -r '.exit')
STATUS=$(printf '%s' "$RESULT" | jq -r '.status')
OUTPUTS=$(printf '%s' "$RESULT" | jq -c '.outputs // {}')

# Warnings and the --allow-missing banner go to stderr; stdout stays clean.
printf '%s' "$RESULT" | jq -r '(.outputs.warnings // [])[] | "list-runtime-assets: warning: " + .' >&2 || true
if [ "$ALLOW_MISSING" -eq 1 ]; then
  SKIPPED=$(printf '%s' "$RESULT" | jq -r '.outputs.downgraded // [] | join(", ")')
  if [ -n "$SKIPPED" ]; then
    printf '*** list-runtime-assets: --allow-missing downgraded missing required source(s) for: %s\n' "$SKIPPED" >&2
  else
    printf '*** list-runtime-assets: --allow-missing had nothing to downgrade.\n' >&2
  fi
fi

case "$EXIT_HINT" in
  0)
    if [ "$FORMAT" = "json" ]; then
      print_envelope "list-runtime-assets" "$STATUS" "$OUTPUTS" "[]" "[]"
    else
      # stdout: TSV rows only (may be empty if the profile selects nothing).
      TEXT=$(printf '%s' "$RESULT" | jq -r '.text')
      [ -z "$TEXT" ] || printf '%s\n' "$TEXT"
    fi
    exit "$ENVELOPE_EXIT_OK" ;;
  1)
    if [ "$FORMAT" = "json" ]; then
      ERRORS=$(printf '%s' "$RESULT" | jq -c '[(.outputs.problems // [])[] | {code: "manifest-invalid", message: .}]')
      print_envelope "list-runtime-assets" "$STATUS" "$OUTPUTS" "[]" "$ERRORS"
    else
      printf '%s\n' "$(printf '%s' "$RESULT" | jq -r '.text')" >&2
    fi
    exit "$ENVELOPE_EXIT_DOMAIN" ;;
  *)
    if [ "$FORMAT" = "json" ]; then
      ERRORS=$(printf '%s' "$RESULT" | jq -c '[(.outputs.problems // [])[] | {code: "invocation", message: .}]')
      print_envelope "list-runtime-assets" "$STATUS" "$OUTPUTS" "[]" "$ERRORS"
    else
      printf '%s\n' "$(printf '%s' "$RESULT" | jq -r '.text')" >&2
    fi
    exit "$ENVELOPE_EXIT_INVOCATION" ;;
esac

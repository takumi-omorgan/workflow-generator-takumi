# macOS
.DS_Store
._*

# Obsidian (personal vault metadata — not kit content)
.obsidian/

# Claude Code — per-project state and dev-mode assets that must not ship
.claude/worktrees/
.claude/skills/
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/receipts/

# AI PR review — generated artifacts and local provider config (config may
# be committed if secret-free; the key always lives in an env var, never here)
ai-review/artifacts/
ai-review/config.json

# Editor / IDE junk
*.swp
*.swo
.idea/
.vscode/

# Backup and temp files
*.bak
*.bak.*
*.tmp

# Personal SSH key material — must not land in the kit repo
mac-connect
mac-connect.pub

# Audit-harness regenerable outputs — re-run audit.py / adr-audit.py / verify.py
# to recreate. Convention documented in notes/skills-audit-*/README.md.
notes/skills-audit-*/skills-audit.csv
notes/skills-audit-*/adr-attributions.csv
notes/skills-audit-*/verification-*.json

{
  "schema": "ai-review-config",
  "version": 1,
  "provider": "openrouter",
  "baseURL": "https://openrouter.ai/api/v1",
  "model": "openai/gpt-4o-mini",
  "apiKeyEnv": "OPENROUTER_API_KEY",
  "timeoutSeconds": 60,
  "maxDiffBytes": 200000,
  "profile": "balanced",
  "headers": {
    "HTTP-Referer": "https://github.com/your-org/your-repo",
    "X-Title": "AI PR Review"
  }
}
